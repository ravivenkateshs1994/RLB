# ─── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript text/xml application/xml
</IfModule>

# ─── Cache Control ────────────────────────────────────────────────────────────
<IfModule mod_headers.c>

    # Content-hashed CSS and JS (dist/): safe to cache for 1 year.
    # The filename contains an 8-char hash that changes whenever the file changes,
    # so browsers automatically fetch the new version after a build.
    <FilesMatch "\.[a-f0-9]{8}\.min\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images and fonts: 1-year cache.
    # If an image is replaced, rename the file or add a query string to bust the cache.
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|woff2|woff|ttf)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>

    # HTML: 1-hour cache so pages stay fresh without hammering the server.
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # robots.txt and sitemap: 1-day cache.
    <FilesMatch "^(robots\.txt|sitemap\.xml)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>

</IfModule>

# ─── Fallback using mod_expires (if mod_headers unavailable) ─────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 1 hour"
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# ─── Custom error page ────────────────────────────────────────────────────────
ErrorDocument 404 /404.html
